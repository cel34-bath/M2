M2_OBJECTS :=
M2_CFILES :=
M2_LASTCFILES :=
M2_OPTCFILES := 
M2_EXTRACFILES :=
M2_MADECFILES :=
M2_SRCFILES := 
M2_CFILES += gmp_aux.c 
M2_LASTCFILES += M2types.c scclib.c M2lib.c M2mem.c gdbm_interface.c memdebug.c
M2_MADECFILES := startup.c
M2_OBJECTS += $(M2_MADECFILES:.c=.o)
M2_CCFILES := boost-regex.cpp main.cpp
M2_OBJECTS += $(M2_CCFILES:.cpp=.o)
M2_HFILES := getpagesize.h types.h M2mem.h startup-header.h startup-trailer.h memdebug.h

M2_DFILES :=
M2_DFILES += arithmetic.d
M2_DFILES += atomic.d
M2_DFILES += M2.d
M2_DFILES += system.d
M2_DFILES += strings.d
M2_DFILES += varstrin.d
M2_DFILES += strings1.d
M2_DFILES += vararray.d
M2_DFILES += ctype.d
M2_DFILES += nets.d
M2_DFILES += varnets.d
M2_DFILES += interrupts.d
M2_DFILES += pthread0.d
M2_DFILES += stdiop0.d 
M2_DFILES += gmp.d
M2_DFILES += ballarith.d
M2_DFILES += engine.dd
ifeq (@XML@,yes)
M2_DFILES += xml.d
M2_LASTCFILES += xml-c.c
else
M2_SRCFILES += xml.d xml-c.c
endif
M2_DFILES += stdio0.d
M2_DFILES += errio.d
M2_DFILES += parse.d
M2_DFILES += expr.d
M2_DFILES += stdio.d
M2_DFILES += stdiop.d
M2_DFILES += err.d
M2_DFILES += gmp1.d
M2_DFILES += tokens.d
M2_DFILES += getline.d
M2_DFILES += lex.d
M2_DFILES += parser.d
M2_DFILES += binding.d
M2_DFILES += basic.d
M2_DFILES += common.d
M2_DFILES += util.d
M2_DFILES += convertr.d
M2_DFILES += struct.d
M2_DFILES += classes.dd
M2_DFILES += buckets.dd
M2_DFILES += equality.dd
M2_DFILES += hashtables.dd
M2_DFILES += regex.dd
M2_DFILES += debugging.dd
M2_DFILES += evaluate.d
M2_DFILES += sets.dd
M2_DFILES += version.dd
ifeq (@MYSQL@,yes)
M2_DFILES += mysql.d
M2_SRCFILES += mysqldummy.d
else
M2_SRCFILES += mysql.d
M2_DFILES += mysqldummy.d
endif
M2_DFILES += pthread.d
M2_DFILES += actors.d
M2_DFILES += actors2.dd
M2_DFILES += actors3.d
M2_DFILES += actors4.d
# M2_DFILES += tasks.d
ifeq (@XML@,yes)
M2_DFILES += xmlactors.d
else
M2_SRCFILES += xmlactors.d
endif
M2_DFILES += actors5.d
M2_DFILES += chrono.dd
M2_DFILES += profiler.dd
M2_DFILES += threads.dd

ifeq (@PYTHON@,yes)
M2_LASTCFILES += python-c.c
M2_DFILES += python.d
else
M2_SRCFILES += python-c.c python.d
endif
M2_DFILES += interface.dd interface2.d
M2_DFILES += texmacs.d
M2_DFILES += monoid.dd
M2_DFILES += monomial_ordering.dd
M2_DFILES += boostmath.dd
M2_DFILES += atomic2.d
ifeq (@JANSSON@,yes)
M2_DFILES += json.d
endif
ifneq (@LIBFFI@,no)
M2_DFILES += ffi.d
else
M2_SRCFILES += ffi.d
endif
# this one is last, because it contains the top level interpreter
M2_DFILES += interp.dd

# should automate these dependencies
actors5.o : @srcdir@/startup-header.h
